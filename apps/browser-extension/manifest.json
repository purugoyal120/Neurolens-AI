{
  "manifest_version": 3,
  "name": "NeuroLens AI",
  "version": "1.0",
  "description": "Personalized accessibility layer for color-blind users.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "css": ["styles.css"],
      "js": [
        "utils/colorTransformer.js",
        "utils/contextReplacer.js",
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
